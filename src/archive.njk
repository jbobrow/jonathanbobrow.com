---
layout: base.njk
title: Archive — Jonathan Bobrow
activePage: archive
permalink: /archive/
---

<main class="archive" id="archive">
  <div class="archive-grid">
    {%- for project in collections.project %}
    <div class="archive-item" data-slug="{{ project.data.slug }}">
      <div class="archive-thumb">
        <img
          src="{{ project.data.heroImage | url }}"
          alt="{{ project.data.heroAlt }}"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="archive-item-info">
        <span class="archive-item-title">{{ project.data.title }}</span>
        <span class="archive-item-role">{{ project.data.role }}</span>
      </div>
    </div>
    {%- endfor %}

    <div class="archive-detail" aria-hidden="true">
    <div class="archive-detail-wrap">
      {%- for project in collections.project %}
      <div class="archive-detail-content" id="archive-detail-{{ project.data.slug }}" hidden>
        <div class="archive-detail-inner">
          <div class="archive-detail-header">
            <div class="archive-detail-header-text">
              <h3>{{ project.data.title }}</h3>
              <p class="project-meta">{{ project.data.role }}<span class="meta-sep"> · </span>{{ project.data.year }}</p>
            </div>
            {%- if project.data.externalLink %}
            <a href="{{ project.data.externalLink }}" class="project-link" target="_blank" rel="noopener">
              visit project
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            </a>
            {%- endif %}
          </div>

          <div class="project-description">
            {{ project.content | safe }}
          </div>

          {%- if project.data.detailImages %}
          <div class="project-gallery">
            {%- for img in project.data.detailImages %}
            <img src="{{ img.src | url }}" alt="{{ img.alt }}" loading="lazy" />
            {%- endfor %}
          </div>
          {%- endif %}

          {%- if project.data.video %}
          <div class="project-video">
            <div class="video-embed">
              <iframe src="{{ project.data.video }}" allowfullscreen loading="lazy"></iframe>
            </div>
          </div>
          {%- endif %}

          <button class="archive-close" aria-label="Close project details">×</button>
        </div>
      </div>
      {%- endfor %}
    </div>
    </div>
  </div>
  <a href="{{ '/' | url }}" class="archive-cta">View featured work <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
</main>
