---
layout: base.njk
title: Jonathan Bobrow
activePage: featured
---

<main id="work">
  {%- for project in collections.featured %}
  <section class="project" id="{{ project.data.slug }}">
    <div class="project-hero" role="button" tabindex="0" aria-expanded="false" aria-controls="detail-{{ project.data.slug }}">
      {%- if project.data.heroSketch %}
      <div class="project-hero-sketch" data-sketch="{{ project.data.heroSketch }}"></div>
      {%- else %}
      <img
        src="{{ project.data.heroImage | url }}"
        alt="{{ project.data.heroAlt }}"
        {% if loop.first %}fetchpriority="high"{% else %}loading="lazy" decoding="async"{% endif %}
      />
      {%- endif %}
      <div class="project-hero-overlay">
        <h2>{{ project.data.title }}</h2>
        <p class="project-meta">{{ project.data.role }}<span class="meta-sep"> · </span>{{ project.data.year }}</p>
      </div>
    </div>

    <div class="project-detail" id="detail-{{ project.data.slug }}" aria-hidden="true">
      <div class="project-detail-inner">
        <button class="project-back" aria-label="Back to featured work"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg> Back to featured work</button>

        <div class="project-description">
          {{ project.content | safe }}
        </div>

        {%- if project.data.detailImages %}
        <div class="project-gallery">
          {%- for img in project.data.detailImages %}
          <img src="{{ img.src | url }}" alt="{{ img.alt }}" loading="lazy" />
          {%- endfor %}
        </div>
        {%- endif %}

        {%- if project.data.video %}
        <div class="project-video">
          <div class="video-embed">
            <iframe src="{{ project.data.video }}" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        {%- endif %}

        {%- if project.data.externalLink %}
        <a href="{{ project.data.externalLink }}" class="project-link" target="_blank" rel="noopener">
          Visit Project <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </a>
        {%- endif %}
        <button class="project-back archive-close" aria-label="Close project">×</button>
      </div>
    </div>
  </section>
  {%- endfor %}
  <a href="{{ '/archive/' | url }}" class="archive-cta">View all work <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
</main>
