<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ site.name }} — {{ site.description }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ site.name }} — {{ site.description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.url }}" />
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href="{{ '/' | url }}" class="site-name"><span>Jonathan</span><span>Bobrow</span></a>
    <nav>
      <a href="{{ '/' | url }}"{% if activePage == "featured" %} class="is-active"{% endif %}>Featured</a>
      <a href="{{ '/archive/' | url }}"{% if activePage == "archive" %} class="is-active"{% endif %}>Archive</a>
      <a href="#about" data-about-toggle>About</a>
    </nav>
  </header>

  <section class="about" id="about" aria-hidden="true">
    <div class="about-inner">
      <p>Jonathan Bobrow is a designer, inventor, and programmer — constantly curious about the space between play, learning, and technology.</p>
      <p>He co-founded <a href="https://move38.com" target="_blank" rel="noopener">Move38</a>, a game technology company, and created <a href="https://blinks.games" target="_blank" rel="noopener">Blinks</a>, a smart tabletop game system. He holds a Master's from the <a href="https://media.mit.edu" target="_blank" rel="noopener">MIT Media Lab</a> and studied Design|Media Arts and Mathematics at UCLA.</p>
      <p>His work spans hardware, software, tangible interfaces, and interactive experiences — guided by the belief that code is just another form of creative expression.</p>
      <div class="about-links">
        <a href="mailto:{{ site.email }}">Email</a>
        <a href="https://instagram.com/jbobrow" target="_blank" rel="noopener">Instagram</a>
        <a href="https://github.com/jbobrow" target="_blank" rel="noopener">GitHub</a>
        <a href="https://cargo.jonathanbobrow.com" target="_blank" rel="noopener">Cargo</a>
      </div>
    </div>
  </section>

  {{ content | safe }}

  <footer class="site-footer">
    <p>&copy; {{ site.name }}</p>
  </footer>

  <script src="{{ '/js/main.js' | url }}" defer></script>
{%- if activePage == "featured" and (collections.featured | hasSketches) %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.0/p5.min.js" defer></script>
{%- for slug in (collections.featured | sketchSlugs) %}
<script src="{{ ('/js/sketches/' + slug + '.js') | url }}" defer></script>
{%- endfor %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-sketch]').forEach(function(el) {
      var name = el.dataset.sketch;
      if (window.p5Sketches && window.p5Sketches[name]) {
        var instance = new p5(function(p) { window.p5Sketches[name](p, el); }, el);
        // Trigger p.windowResized when the container resizes (e.g. grid animation)
        if (window.ResizeObserver) {
          new ResizeObserver(function() {
            if (instance && instance.windowResized) instance.windowResized();
          }).observe(el);
        }
      }
    });
  });
</script>
{%- endif %}
</body>
</html>
