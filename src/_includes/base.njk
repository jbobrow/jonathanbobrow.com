<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ site.name }} — {{ site.description }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ site.name }} — {{ site.description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.url }}" />
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href="{{ '/' | url }}" class="site-name"><span>Jonathan</span><span>Bobrow</span></a>
    <nav>
      <a href="{{ '/' | url }}"{% if activePage == "featured" %} class="is-active"{% endif %}>Featured</a>
      <a href="{{ '/archive/' | url }}"{% if activePage == "archive" %} class="is-active"{% endif %}>Archive</a>
      <a href="#about" data-about-toggle>About</a>
    </nav>
  </header>

  <section class="about" id="about" aria-hidden="true">
    <div class="about-inner">
      <p>Jonathan Bobrow is a designer, inventor, and programmer — constantly curious about the space between play, learning, and technology.</p>
      <p>He co-founded <a href="https://move38.com" target="_blank" rel="noopener">Move38</a>, a game technology company, and created <a href="https://blinks.games" target="_blank" rel="noopener">Blinks</a>, a smart tabletop game system. He holds a Master's from the <a href="https://media.mit.edu" target="_blank" rel="noopener">MIT Media Lab</a> and studied Design|Media Arts and Mathematics at UCLA.</p>
      <p>His work spans hardware, software, tangible interfaces, and interactive experiences — guided by the belief that code is just another form of creative expression.</p>
      <div class="about-links">
        <a href="mailto:{{ site.email }}"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> Email</a>
        <a href="https://www.linkedin.com/in/jonathanbobrow/" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 12h.01"/><path d="M16 6V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M22 13a18.15 18.15 0 0 1-20 0"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg> LinkedIn</a>
        <a href="https://instagram.com/jbobrow" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg> Instagram</a>
        <a href="https://github.com/jbobrow" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg> GitHub</a>
        <a href="https://cargo.jonathanbobrow.com" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg> Old Portfolio</a>
      </div>
    </div>
  </section>

  {{ content | safe }}

  <footer class="site-footer">
    <p>&copy; {{ site.name }}</p>
  </footer>

  <script>window.siteUrls={home:'{{ "/" | url }}',archive:'{{ "/archive/" | url }}',work:'{{ "/work/" | url }}'};</script>
  <script src="{{ '/js/main.js' | url }}" defer></script>
{%- if activePage == "featured" and (collections.featured | hasSketches) %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.0/p5.min.js" defer></script>
{%- for slug in (collections.featured | sketchSlugs) %}
<script src="{{ ('/js/sketches/' + slug + '.js') | url }}" defer></script>
{%- endfor %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-sketch]').forEach(function(el) {
      var name = el.dataset.sketch;
      if (window.p5Sketches && window.p5Sketches[name]) {
        var instance = new p5(function(p) { window.p5Sketches[name](p, el); }, el);
        // Trigger p.windowResized when the container resizes (e.g. grid animation)
        if (window.ResizeObserver) {
          new ResizeObserver(function() {
            if (instance && instance.windowResized) instance.windowResized();
          }).observe(el);
        }
      }
    });
  });
</script>
{%- endif %}
</body>
</html>
